// ContentPro - MySQL/MariaDB Schema (Production)
// Application SaaS de gestion de contenu et d'automatisation IA

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

enum UserRole {
  ADMIN
  CLIENT
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String?          @db.VarChar(255)
  password        String?          @db.Text
  role            UserRole         @default(CLIENT)
  image           String?          @db.VarChar(500)
  emailVerified   DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  // Relations
  accounts        Account[]
  sessions        AuthSession[]
  subscription    Subscription?
  contentSessions ContentSession[]
  usageRecords    UsageRecord[]
  businessProfile BusinessProfile?

  @@map("users")
}

model BusinessProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  brandName        String?  @db.VarChar(255)
  companyName      String?  @db.VarChar(255)
  targetAudience   String?  @db.Text
  valueProposition String?  @db.Text
  toneOfVoice      String?  @db.VarChar(100)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("business_profiles")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String  @db.VarChar(50)
  provider          String  @db.VarChar(50)
  providerAccountId String  @db.VarChar(255)
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.VarChar(50)
  scope             String? @db.Text
  id_token          String? @db.Text
  session_state     String? @db.VarChar(255)
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique @db.VarChar(255)
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String   @db.VarChar(255)
  token      String   @unique @db.VarChar(255)
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// SUBSCRIPTION PLANS
// ============================================

enum PlanType {
  STARTER
  CREATOR
  BUSINESS
  AGENCY
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

model Plan {
  id                   String         @id @default(cuid())
  name                 String         @db.VarChar(255)
  type                 PlanType       @unique
  priceMonthly         Float
  sessionsIncluded     Int
  pricePerExtraSession Float
  maxUsers             Int            @default(1)
  features             String         @db.Text
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  subscriptions        Subscription[]

  @@map("plans")
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  planId                 String
  status                 SubscriptionStatus @default(TRIAL)
  stripeCustomerId       String?            @db.VarChar(255)
  stripeSubscriptionId   String?            @db.VarChar(255)
  stripePriceId          String?            @db.VarChar(255)
  stripeCurrentPeriodEnd DateTime?
  trialStartsAt          DateTime?
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  sessionsUsed           Int                @default(0)
  sessionsLimit          Int
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  plan                   Plan               @relation(fields: [planId], references: [id])
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ============================================
// CONTENT SESSIONS
// ============================================

enum SessionStatus {
  DRAFT
  PROCESSING
  COMPLETED
  FAILED
}

model ContentSession {
  id          String        @id @default(cuid())
  userId      String
  title       String?       @db.VarChar(500)
  context     String?       @db.Text
  status      SessionStatus @default(DRAFT)
  metadata    String?       @db.Text
  artisticDir String?       @db.Text
  thumbnails  String?       @db.Text
  socialPosts String?       @db.Text
  tokensUsed  Int           @default(0)
  cost        Float         @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  completedAt DateTime?
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("content_sessions")
}

// ============================================
// USAGE TRACKING
// ============================================

model UsageRecord {
  id           String   @id @default(cuid())
  userId       String
  action       String   @db.VarChar(100)
  resourceId   String?  @db.VarChar(255)
  resourceType String?  @db.VarChar(100)
  tokensUsed   Int      @default(0)
  cost         Float    @default(0)
  metadata     String?  @db.Text
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("usage_records")
}

// ============================================
// SITE SETTINGS
// ============================================

model SiteSettings {
  id                 String   @id @default(cuid())
  siteName           String   @default("ContentPro") @db.VarChar(255)
  siteUrl            String   @default("https://contentpro.fr") @db.VarChar(500)
  siteEmail          String   @default("contact@contentpro.fr") @db.VarChar(255)
  timezone           String   @default("Europe/Paris") @db.VarChar(100)
  defaultUserGroup   String   @default("CLIENT") @db.VarChar(50)
  enableRecaptcha    Boolean  @default(false)
  recaptchaSiteKey   String?  @db.VarChar(255)
  recaptchaSecretKey String?  @db.VarChar(255)
  enableAnalytics    Boolean  @default(false)
  analyticsId        String?  @db.VarChar(255)
  oauthEnabled       Boolean  @default(false)
  facebookOAuth      String?  @db.Text
  twitterOAuth       String?  @db.Text
  linkedinOAuth      String?  @db.Text
  googleOAuth        String?  @db.Text
  zaiApiKey          String?  @db.VarChar(255)
  openaiApiKey       String?  @db.VarChar(255)
  anthropicApiKey    String?  @db.VarChar(255)
  googleAiApiKey     String?  @db.VarChar(255)
  mistralApiKey      String?  @db.VarChar(255)
  replicateApiKey    String?  @db.VarChar(255)
  stabilityApiKey    String?  @db.VarChar(255)
  smtpEnabled        Boolean  @default(false)
  smtpHost           String?  @db.VarChar(255)
  smtpPort           Int?
  smtpUser           String?  @db.VarChar(255)
  smtpPassword       String?  @db.VarChar(255)
  smtpFromEmail      String?  @db.VarChar(255)
  smtpFromName       String?  @db.VarChar(255)
  smtpEncryption     String   @default("ssl") @db.VarChar(50)
  twoFactorEnabled   Boolean  @default(false)
  rateLimitEnabled   Boolean  @default(true)
  rateLimitRequests  Int      @default(60)
  rateLimitWindow    Int      @default(60)
  maintenanceMode    Boolean  @default(false)
  maintenanceMessage String?  @db.Text
  gdprEnabled        Boolean  @default(true)
  cookieValidityDays Int      @default(7)
  defaultLanguage    String   @default("fr") @db.VarChar(10)
  availableLanguages String   @default("fr") @db.VarChar(255)
  defaultCurrency    String   @default("EUR") @db.VarChar(10)
  // Email settings
  emailEnabled       Boolean  @default(false)
  emailProvider      String?  @db.VarChar(100)
  // SMTP extended
  smtpUsername       String?  @db.VarChar(255)
  smtpEncryptionType String?  @db.VarChar(50)
  // Email providers
  sendgridApiKey     String?  @db.VarChar(255)
  brevoApiKey        String?  @db.VarChar(255)
  mailchimpApiKey    String?  @db.VarChar(255)
  amazonSesApiKey    String?  @db.VarChar(255)
  amazonSesSecretKey String?  @db.VarChar(255)
  mailgunApiKey      String?  @db.VarChar(255)
  mailgunDomain      String?  @db.VarChar(255)
  postmarkApiKey     String?  @db.VarChar(255)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("site_settings")
}

// ============================================
// LEGAL PAGES
// ============================================

model LegalPage {
  id        String   @id @default(cuid())
  type      String   @unique @db.VarChar(50)
  title     String   @db.VarChar(255)
  content   String   @db.LongText
  updatedAt DateTime @updatedAt

  @@map("legal_pages")
}

// ============================================
// ORCHESTRATOR - CATEGORIES
// ============================================

model AgentCategory {
  id            String   @id @default(cuid())
  name          String   @db.VarChar(255)
  nameEn        String?  @db.VarChar(255)
  nameEs        String?  @db.VarChar(255)
  slug          String   @unique @db.VarChar(255)
  description   String?  @db.Text
  descriptionEn String?  @db.Text
  descriptionEs String?  @db.Text
  icon          String   @default("Bot") @db.VarChar(100)
  color         String   @default("orange") @db.VarChar(50)
  accessLevel   String   @default("ALL") @db.VarChar(50)
  displayOrder  Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  agents        Agent[]

  @@map("agent_categories")
}

// ============================================
// ORCHESTRATOR - AGENTS
// ============================================

model Agent {
  id            String        @id @default(cuid())
  name          String        @db.VarChar(255)
  slug          String        @unique @db.VarChar(255)
  description   String?       @db.Text
  avatar        String?       @db.VarChar(500)
  color         String        @default("orange") @db.VarChar(50)
  systemPrompt  String        @db.Text
  modelProvider String        @default("openrouter") @db.VarChar(100)
  modelName     String        @default("claude-sonnet-4-6") @db.VarChar(100)
  temperature   Float         @default(0.7)
  maxTokens     Int           @default(4096)
  status        String        @default("ACTIVE") @db.VarChar(50)
  categoryId    String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  category      AgentCategory @relation(fields: [categoryId], references: [id])
  executions    ExecutionLog[]
  skills        Skill[]

  @@map("agents")
}

// ============================================
// ORCHESTRATOR - SKILLS
// ============================================

model Skill {
  id                  String          @id @default(cuid())
  name                String          @db.VarChar(255)
  slug                String          @unique @db.VarChar(255)
  description         String?         @db.Text
  type                String          @default("GENERATION") @db.VarChar(50)
  promptTemplate      String          @db.Text
  inputSchema         String          @db.Text
  outputSchema        String          @db.Text
  examples            String?         @db.Text
  fallbackPrompt      String?         @db.Text
  maxRetries          Int             @default(3)
  timeoutMs           Int             @default(30000)
  modelOverride       String?         @db.VarChar(100)
  temperatureOverride Float?
  isActive            Boolean         @default(true)
  version             Int             @default(1)
  agentId             String
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  executions          ExecutionLog[]
  scheduledTasks      ScheduledTask[]
  tools               SkillTool[]
  versions            SkillVersion[]
  agent               Agent           @relation(fields: [agentId], references: [id])

  @@map("skills")
}

model SkillVersion {
  id             String   @id @default(cuid())
  skillId        String
  version        Int
  promptTemplate String   @db.Text
  inputSchema    String   @db.Text
  outputSchema   String   @db.Text
  examples       String?  @db.Text
  changeNote     String?  @db.VarChar(500)
  createdAt      DateTime @default(now())
  skill          Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, version])
  @@map("skill_versions")
}

// ============================================
// ORCHESTRATOR - TOOLS
// ============================================

model Tool {
  id             String         @id @default(cuid())
  name           String         @db.VarChar(255)
  slug           String         @unique @db.VarChar(255)
  description    String?        @db.Text
  type           String         @default("API") @db.VarChar(50)
  endpoint       String?        @db.VarChar(500)
  method         String         @default("POST") @db.VarChar(10)
  headers        String?        @db.Text
  authentication String?        @db.Text
  inputSchema    String?        @db.Text
  outputSchema   String?        @db.Text
  costPerCall    Float          @default(0)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  executions     ExecutionLog[]
  skills         SkillTool[]

  @@map("tools")
}

model SkillTool {
  id      String @id @default(cuid())
  skillId String
  toolId  String
  order   Int    @default(0)
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  tool    Tool   @relation(fields: [toolId], references: [id])

  @@unique([skillId, toolId])
  @@map("skill_tools")
}

// ============================================
// ORCHESTRATOR - EXECUTION LOGS
// ============================================

model ExecutionLog {
  id         String   @id @default(cuid())
  status     String   @db.VarChar(50)
  input      String?  @db.Text
  output     String?  @db.Text
  error      String?  @db.Text
  durationMs Int?
  tokensUsed Int?
  cost       Float?
  agentId    String?
  skillId    String?
  toolId     String?
  createdAt  DateTime @default(now())
  agent      Agent?   @relation(fields: [agentId], references: [id])
  skill      Skill?   @relation(fields: [skillId], references: [id])
  tool       Tool?    @relation(fields: [toolId], references: [id])

  @@index([createdAt])
  @@map("execution_logs")
}

// ============================================
// ORCHESTRATOR - SCHEDULER
// ============================================

model ScheduledTask {
  id          String    @id @default(cuid())
  name        String    @db.VarChar(255)
  description String?   @db.Text
  cron        String    @db.VarChar(100)
  skillId     String
  inputData   String?   @db.Text
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  status      String    @default("ACTIVE") @db.VarChar(50)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  skill       Skill     @relation(fields: [skillId], references: [id])

  @@map("scheduled_tasks")
}

// ============================================
// ORCHESTRATION CONFIGURATION
// ============================================

model OrchestrationConfig {
  id         String   @id @default(cuid())
  name       String   @db.VarChar(255)
  isDefault  Boolean  @default(false)
  isActive   Boolean  @default(true)
  categories String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("orchestration_configs")
}

// ============================================
// POSTS (Blog/Content)
// ============================================

model Post {
  id        String   @id @default(cuid())
  title     String   @db.VarChar(500)
  content   String?  @db.LongText
  published Boolean  @default(false)
  authorId  String   @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// EMAIL TEMPLATES
// ============================================

model EmailTemplate {
  id        String   @id @default(cuid())
  type      String   @unique @db.VarChar(100)
  subject   String   @db.VarChar(500)
  body      String   @db.LongText
  variables String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

// ============================================
// SUPPORT TICKETS
// ============================================

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

model SupportTicket {
  id        String         @id @default(cuid())
  userId    String
  subject   String         @db.VarChar(500)
  message   String         @db.Text
  priority  TicketPriority @default(MEDIUM)
  status    TicketStatus   @default(OPEN)
  response  String?        @db.Text
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId])
  @@map("support_tickets")
}
