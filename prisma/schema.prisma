// ContentPro - PostgreSQL Schema
// Application SaaS de gestion de contenu et d'automatisation IA

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRODUCTION_DB_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

enum UserRole {
  ADMIN
  CLIENT
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String?
  password        String?
  role            UserRole         @default(CLIENT)
  image           String?
  emailVerified   DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  // Relations
  accounts        Account[]
  sessions        AuthSession[]
  subscription    Subscription?
  contentSessions ContentSession[]
  usageRecords    UsageRecord[]
  businessProfile BusinessProfile?

  @@map("users")
}

model BusinessProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  brandName        String?
  companyName      String?
  targetAudience   String?
  valueProposition String?
  toneOfVoice      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("business_profiles")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// SUBSCRIPTION PLANS
// ============================================

enum PlanType {
  STARTER
  CREATOR
  BUSINESS
  AGENCY
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

model Plan {
  id                   String         @id @default(cuid())
  name                 String
  type                 PlanType       @unique
  priceMonthly         Float
  sessionsIncluded     Int
  pricePerExtraSession Float
  maxUsers             Int            @default(1)
  features             String
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  subscriptions        Subscription[]

  @@map("plans")
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  planId                 String
  status                 SubscriptionStatus @default(TRIAL)
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  trialStartsAt          DateTime?
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  sessionsUsed           Int                @default(0)
  sessionsLimit          Int
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  plan                   Plan               @relation(fields: [planId], references: [id])
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ============================================
// CONTENT SESSIONS
// ============================================

enum SessionStatus {
  DRAFT
  PROCESSING
  COMPLETED
  FAILED
}

model ContentSession {
  id          String        @id @default(cuid())
  userId      String
  title       String?
  context     String?
  status      SessionStatus @default(DRAFT)
  metadata    String?
  artisticDir String?
  thumbnails  String?
  socialPosts String?
  tokensUsed  Int           @default(0)
  cost        Float         @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  completedAt DateTime?
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("content_sessions")
}

// ============================================
// USAGE TRACKING
// ============================================

model UsageRecord {
  id           String   @id @default(cuid())
  userId       String
  action       String
  resourceId   String?
  resourceType String?
  tokensUsed   Int      @default(0)
  cost         Float    @default(0)
  metadata     String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("usage_records")
}

// ============================================
// SITE SETTINGS
// ============================================

model SiteSettings {
  id                 String   @id @default(cuid())
  siteName           String   @default("ContentPro")
  siteUrl            String   @default("https://contentpro.fr")
  siteEmail          String   @default("contact@contentpro.fr")
  timezone           String   @default("Europe/Paris")
  defaultUserGroup   String   @default("CLIENT")
  enableRecaptcha    Boolean  @default(false)
  recaptchaSiteKey   String?
  recaptchaSecretKey String?
  enableAnalytics    Boolean  @default(false)
  analyticsId        String?
  oauthEnabled       Boolean  @default(false)
  facebookOAuth      String?
  twitterOAuth       String?
  linkedinOAuth      String?
  googleOAuth        String?
  zaiApiKey          String?
  openaiApiKey       String?
  openRouterApiKey   String?
  anthropicApiKey    String?
  googleAiApiKey     String?
  mistralApiKey      String?
  replicateApiKey    String?
  stabilityApiKey    String?
  smtpEnabled        Boolean  @default(false)
  smtpHost           String?
  smtpPort           Int?
  smtpUser           String?
  smtpPassword       String?
  smtpFromEmail      String?
  smtpFromName       String?
  smtpEncryption     String   @default("ssl")
  twoFactorEnabled   Boolean  @default(false)
  rateLimitEnabled   Boolean  @default(true)
  rateLimitRequests  Int      @default(60)
  rateLimitWindow    Int      @default(60)
  maintenanceMode    Boolean  @default(false)
  maintenanceMessage String?
  gdprEnabled        Boolean  @default(true)
  cookieValidityDays Int      @default(7)
  defaultLanguage    String   @default("fr")
  availableLanguages String   @default("fr")
  defaultCurrency    String   @default("EUR")
  // Email settings
  emailEnabled       Boolean  @default(false)
  emailProvider      String?
  // SMTP extended
  smtpUsername       String?
  smtpEncryptionType String?
  // Email providers
  sendgridApiKey     String?
  brevoApiKey        String?
  mailchimpApiKey    String?
  amazonSesApiKey    String?
  amazonSesSecretKey String?
  mailgunApiKey      String?
  mailgunDomain      String?
  postmarkApiKey     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("site_settings")
}

// ============================================
// LEGAL PAGES
// ============================================

model LegalPage {
  id        String   @id @default(cuid())
  type      String   @unique
  title     String
  content   String
  updatedAt DateTime @updatedAt

  @@map("legal_pages")
}

// ============================================
// ORCHESTRATOR - CATEGORIES
// ============================================

model AgentCategory {
  id            String   @id @default(cuid())
  name          String
  nameEn        String?
  nameEs        String?
  slug          String   @unique
  description   String?
  descriptionEn String?
  descriptionEs String?
  icon          String   @default("Bot")
  color         String   @default("orange")
  accessLevel   String   @default("ALL")
  displayOrder  Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  agents        Agent[]

  @@map("agent_categories")
}

// ============================================
// ORCHESTRATOR - AGENTS
// ============================================

model Agent {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?
  avatar        String?
  color         String         @default("orange")
  systemPrompt  String
  modelProvider String         @default("openrouter")
  modelName     String         @default("claude-sonnet-4-6")
  temperature   Float          @default(0.7)
  maxTokens     Int            @default(4096)
  status        String         @default("ACTIVE")
  categoryId    String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  category      AgentCategory  @relation(fields: [categoryId], references: [id])
  executions    ExecutionLog[]
  skills        Skill[]

  @@map("agents")
}

// ============================================
// ORCHESTRATOR - SKILLS
// ============================================

model Skill {
  id                  String          @id @default(cuid())
  name                String
  slug                String          @unique
  description         String?
  type                String          @default("GENERATION")
  promptTemplate      String
  inputSchema         String
  outputSchema        String
  examples            String?
  fallbackPrompt      String?
  maxRetries          Int             @default(3)
  timeoutMs           Int             @default(30000)
  modelOverride       String?
  temperatureOverride Float?
  isActive            Boolean         @default(true)
  version             Int             @default(1)
  agentId             String
  files               Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  executions          ExecutionLog[]
  scheduledTasks      ScheduledTask[]
  tools               SkillTool[]
  versions            SkillVersion[]
  agent               Agent           @relation(fields: [agentId], references: [id])

  @@map("skills")
}

model SkillVersion {
  id             String   @id @default(cuid())
  skillId        String
  version        Int
  promptTemplate String
  inputSchema    String
  outputSchema   String
  files          Json?
  examples       String?
  changeNote     String?
  createdAt      DateTime @default(now())
  skill          Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, version])
  @@map("skill_versions")
}

// ============================================
// ORCHESTRATOR - TOOLS
// ============================================

model Tool {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  description    String?
  type           String         @default("API")
  endpoint       String?
  method         String         @default("POST")
  headers        String?
  authentication String?
  inputSchema    String?
  outputSchema   String?
  costPerCall    Float          @default(0)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  executions     ExecutionLog[]
  skills         SkillTool[]

  @@map("tools")
}

model SkillTool {
  id      String @id @default(cuid())
  skillId String
  toolId  String
  order   Int    @default(0)
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  tool    Tool   @relation(fields: [toolId], references: [id])

  @@unique([skillId, toolId])
  @@map("skill_tools")
}

// ============================================
// ORCHESTRATOR - EXECUTION LOGS
// ============================================

model ExecutionLog {
  id         String   @id @default(cuid())
  status     String
  input      String?
  output     String?
  error      String?
  durationMs Int?
  tokensUsed Int?
  cost       Float?
  agentId    String?
  skillId    String?
  toolId     String?
  createdAt  DateTime @default(now())
  agent      Agent?   @relation(fields: [agentId], references: [id])
  skill      Skill?   @relation(fields: [skillId], references: [id])
  tool       Tool?    @relation(fields: [toolId], references: [id])

  @@map("execution_logs")
}

// ============================================
// ORCHESTRATOR - SCHEDULER
// ============================================

model ScheduledTask {
  id          String    @id @default(cuid())
  name        String
  description String?
  cron        String
  skillId     String
  inputData   String?
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  status      String    @default("ACTIVE")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  skill       Skill     @relation(fields: [skillId], references: [id])

  @@map("scheduled_tasks")
}

// ============================================
// ORCHESTRATION CONFIGURATION
// ============================================

model OrchestrationConfig {
  id         String   @id @default(cuid())
  name       String
  isDefault  Boolean  @default(false)
  isActive   Boolean  @default(true)
  categories String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("orchestration_configs")
}

// ============================================
// POSTS (Blog/Content)
// ============================================

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// EMAIL TEMPLATES
// ============================================

model EmailTemplate {
  id        String   @id @default(cuid())
  type      String   @unique
  subject   String
  body      String
  variables String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

// ============================================
// SUPPORT TICKETS
// ============================================

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

model SupportTicket {
  id        String        @id @default(cuid())
  userId    String
  subject   String
  message   String
  priority  TicketPriority @default(MEDIUM)
  status    TicketStatus   @default(OPEN)
  response  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("support_tickets")
}

// ============================================
// ESC SKILLS COLLECTION
// ============================================

model EscSkill {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  category      String   @default("general")
  source        String   @default("esc-skills")
  providerUrl   String?
  version       String   @default("1.0.0")
  contentHash   String?
  promptContent String   @db.Text
  files         Json?
  tags          String?
  isActive      Boolean  @default(false)
  isInstalled   Boolean  @default(true)
  icon          String   @default("Zap")
  color         String   @default("orange")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("esc_skills")
}

model SkillProvider {
  id        String   @id @default(cuid())
  name      String
  url       String   @unique
  type      String   @default("GITHUB_REPO") // GITHUB_REPO, GITHUB_FILE, SMITHERY
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("esc_skill_providers")
}
